<?xml version="1.0" encoding="UTF-8"?>
<!--
  macOS launchd job: run instagram-inbox-kit once an hour.

  Install (per-user LaunchAgent):
    1. Edit the paths below: replace /ABSOLUTE/PATH/TO/instagram-inbox-kit with
       the real repo path, and set the label to something unique to you.
    2. Copy to ~/Library/LaunchAgents/com.example.instagram-inbox.plist
    3. launchctl bootstrap gui/$(id -u) ~/Library/LaunchAgents/com.example.instagram-inbox.plist
    4. Check:  launchctl list | grep instagram-inbox
    Unload:    launchctl bootout gui/$(id -u)/com.example.instagram-inbox

  Secrets: put your keys in the repo's .env (run.sh loads it). Do NOT hardcode
  API keys in this plist — it is world-readable in your LaunchAgents folder.
-->
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.example.instagram-inbox</string>

    <key>ProgramArguments</key>
    <array>
        <string>/bin/bash</string>
        <string>/ABSOLUTE/PATH/TO/instagram-inbox-kit/scripts/run.sh</string>
    </array>

    <key>WorkingDirectory</key>
    <string>/ABSOLUTE/PATH/TO/instagram-inbox-kit</string>

    <!-- Poll every hour. Hourly is deliberate: it is frequent enough to feel
         live, infrequent enough to stay gentle on a watched account. -->
    <key>StartInterval</key>
    <integer>3600</integer>

    <key>RunAtLoad</key>
    <false/>

    <key>Nice</key>
    <integer>10</integer>

    <key>StandardOutPath</key>
    <string>/ABSOLUTE/PATH/TO/instagram-inbox-kit/logs/launchd.log</string>
    <key>StandardErrorPath</key>
    <string>/ABSOLUTE/PATH/TO/instagram-inbox-kit/logs/launchd.err.log</string>
</dict>
</plist>
