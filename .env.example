# ============================================================================
# instagram-inbox-kit — environment configuration
# Copy to `.env` and fill in. `.env` is git-ignored. NEVER commit real values.
# Load order: process env wins over .env (python-dotenv, load_dotenv override=False).
# ============================================================================

# --- LLM transport (REQUIRED — pick ONE) -----------------------------------
# The kit makes exactly ONE LLM call per captured item (classify + extract),
# plus an optional second call for "AI idea" posts. Route it either way:
#
# Option A — Anthropic API directly:
LLM_BACKEND=anthropic
ANTHROPIC_API_KEY=
LLM_MODEL=claude-haiku-4-5
# LLM_API_VERSION=2023-06-01     # anthropic-version header (default shown)

# Option B — any OpenAI-compatible endpoint (OpenAI, OpenRouter, a local
# llama.cpp / vLLM / Ollama server, an internal proxy, etc). Uncomment these
# and set LLM_BACKEND=openai:
# LLM_BACKEND=openai
# LLM_BASE_URL=https://api.openai.com/v1        # must expose /chat/completions
# LLM_API_KEY=
# LLM_MODEL=gpt-4o-mini

# --- Speech transcription: HOW should it turn reel audio into text? --------
# TRANSCRIBE_BACKEND = auto | deepgram | whisper | none
#   auto     (default) → Deepgram if a key is set below, else OFF (audio skipped;
#                        captions + on-screen text still carry the post).
#   deepgram → cloud, fast, works on ANY machine. Free account at deepgram.com
#              gives generous free credits that last a long time. Audio is sent
#              to Deepgram. Set DEEPGRAM_API_KEY below.
#   whisper  → runs ON THIS COMPUTER, no account, fully private — but wants a
#              reasonably powerful machine. Needs:  pip install "ig-inbox-kit[whisper]"
#   none     → never transcribe speech.
# Not sure? Run `python -m ig_inbox.doctor` — it reports what's available and
# whether this machine looks strong enough for on-device Whisper.
TRANSCRIBE_BACKEND=auto

DEEPGRAM_API_KEY=
# DEEPGRAM_MODEL=nova-3
# DEEPGRAM_COST_PER_MIN=0.0043   # only used for the cost line in logs
# WHISPER_MODEL=base             # base|small|medium — bigger = better + slower

# --- OCR backend (on-screen text) ------------------------------------------
# auto  = macOS Vision if the compiled binary exists, else tesseract, else none
# vision = force the compiled macOS Vision CLI (Mac only; built by setup)
# tesseract = force Tesseract (cross-platform; `brew/apt install tesseract`)
# none  = disable OCR
OCR_BACKEND=auto

# --- Web enrichment (OPTIONAL) ---------------------------------------------
# Restaurants get address/hours/rating; books get a Goodreads rating. This
# needs an LLM that can browse the web.
#   none          = disabled (default; restaurants/books keep only post facts)
#   anthropic_web = Anthropic Messages API with the web_search tool
#                   (requires ANTHROPIC_API_KEY above and account web access)
ENRICH_BACKEND=none

# --- Notifications (OPTIONAL) ----------------------------------------------
# How the kit tells you when Instagram needs a human (challenge) or a run
# breaks 3× in a row.
#   stdout  = print to console / log (default)
#   webhook = HTTP POST {"text": "..."} to NOTIFY_WEBHOOK_URL (Slack/Discord/etc)
NOTIFY_BACKEND=stdout
# NOTIFY_WEBHOOK_URL=

# --- Knowledge-base hook (OPTIONAL) ----------------------------------------
# Fire a shell command per captured record so you can push it into your own
# memory system / vector DB / note app. The record JSON is passed on stdin.
# Leave blank to disable (default no-op).
# KB_HOOK_CMD=/path/to/my/ingest.sh

# --- Instagram email-challenge auto-resolver (OPTIONAL) --------------------
# When Instagram emails a 6-digit login code, the kit can read it from an IMAP
# inbox automatically (no human step). Point this at the mailbox that receives
# the bot account's security email. Leave IMAP_HOST blank to fall back to the
# interactive prompt (you type the code in yourself during login).
# IMAP_HOST=imap.gmail.com
# IMAP_PORT=993
# IMAP_USER=
# IMAP_PASSWORD=          # use an app-specific password, not your main one

# --- Paths (OPTIONAL — sensible defaults) ----------------------------------
# Where runtime data/state/logs live. Default: alongside the repo.
# IG_INBOX_HOME=/var/lib/ig-inbox
# IG_INBOX_DATA_DIR=
# IG_INBOX_STATE_DIR=
# IG_INBOX_LOG_DIR=
# Credentials + IG session file (default: ~/.ig_inbox/credentials, chmod 600).
# IG_INBOX_CRED_DIR=

# --- Tool paths (OPTIONAL — auto-detected from PATH if unset) --------------
# FFMPEG_BIN=/opt/homebrew/bin/ffmpeg
# FFPROBE_BIN=/opt/homebrew/bin/ffprobe
# TESSERACT_BIN=tesseract

# --- "Fit for us" context for AI-idea posts (OPTIONAL) ---------------------
# One sentence/paragraph describing YOUR setup, so the assessment is grounded.
# ASSISTANT_CONTEXT=I run a personal automation stack and want to know whether an AI post is worth adopting.
